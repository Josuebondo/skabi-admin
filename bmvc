PHP;

        $contenu = str_replace('{NOM}', $nom, $template);
        $contenu = str_replace('{nom}', strtolower($nom), $contenu);

        file_put_contents($chemin, $contenu);

        $this->succes("Contrôleur {$nom} créé avec succès!");
        $this->info("Chemin: {$chemin}");
    }

